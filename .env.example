# Frontend env vars
VITE_APP_ID=atlas-standalone
VITE_APP_BASE_URL=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Production: set VITE_API_URL to your Express API origin (required if not using Supabase)
# VITE_API_URL=https://api.example.com
# Optional: allow localStorage demo mode in production builds (not for real customers)
# VITE_ALLOW_LOCAL_DEMO=false
# If you deploy only static files with NO /api proxy, set (shows backend-required screen):
# VITE_DISABLE_RELATIVE_API=true
# Comma-separated emails that see the Platform admin UI (must match server PLATFORM_ADMIN_EMAILS)
# VITE_PLATFORM_ADMIN_EMAILS=you@company.com
VITE_OPENAI_API_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=

# API runtime env vars (Express backend)
NODE_ENV=development
PORT=3001
# Optional: path to `dist/` after `npm run build` — serves the SPA from Express (fixes deep links like /contact when API + UI share one origin)
# STATIC_DIST_PATH=/absolute/path/to/atlas/dist
FRONTEND_URL=http://localhost:5173
DATABASE_URL=postgresql://atlas_user:atlas_local_pw_2024@127.0.0.1:5432/atlas_db
JWT_SECRET=replace_with_very_long_random_secret_32_chars_minimum
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_TTL_DAYS=30
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
DATA_RETENTION_DAYS=365
REDIS_URL=redis://localhost:6379
SENTRY_DSN=

# Stripe (Express) — checkout, portal, webhooks
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_STARTER=price_xxx
# OpenAI for /api/ai/chat (do not expose to browser; remove VITE_OPENAI in production)
# OPENAI_API_KEY=
# Resend for /api/email/send
# RESEND_API_KEY=
# EMAIL_FROM=noreply@yourdomain.com
# Inbox for public contact form POST /api/public/contact (same Resend account)
# CONTACT_INBOX_EMAIL=support@yourdomain.com
# Comma-separated — full access to GET /api/platform/*
# PLATFORM_ADMIN_EMAILS=you@company.com

# Optional async/integration env vars used by the alternate backend scaffold
JWT_ACCESS_SECRET=change_me_access_secret_123456
JWT_REFRESH_SECRET=change_me_refresh_secret_123456
ACCESS_TOKEN_TTL=15m
S3_ENDPOINT=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=

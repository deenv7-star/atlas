# ─────────────────────────────────────────────────────────────────────────────
# ATLAS — Environment Variables
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application (optional) ────────────────────────────────────────────────────
# A human-readable identifier for this deployment.
VITE_APP_ID=atlas-standalone

# The public base URL of the app (used for redirects, e.g. https://myapp.com).
# Leave blank for local development.
VITE_APP_BASE_URL=

# ── Supabase (required for production / real backend) ─────────────────────────
#
# 1. Create a free project at https://supabase.com
# 2. Go to Project Settings → API
# 3. Copy the "Project URL" and "anon / public" key below
# 4. Run supabase/schema.sql in the Supabase SQL Editor to create all tables
#    with Row Level Security enabled
#
# When these two variables are set the app uses Supabase for all data storage
# and authentication (email + password with session persistence).
# When they are NOT set the app falls back to localStorage so you can still
# run it locally without a database.
#
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── AI / LLM Integration (optional) ──────────────────────────────────────────
# Add your OpenAI API key to enable the AI Assistant page.
# Without this key the assistant will display a helpful configuration message.
VITE_OPENAI_API_KEY=

# ── Stripe (optional) ────────────────────────────────────────────────────────
# Required only if you use the Stripe payment integration.
VITE_STRIPE_PUBLISHABLE_KEY=
